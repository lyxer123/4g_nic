+    struct lfs_fsinfo fsinfo;
+    lfs_fs_stat(&lfs, &fsinfo) => 0;
+    assert(fsinfo.disk_version == LFS_DISK_VERSION-1);
+
+    lfs_file_open(&lfs, &file, "test", LFS_O_RDONLY) => 0;
