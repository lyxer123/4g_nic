# Do not force unicore here: main sdkconfig.defaults uses dual-core for ESP32-S3 + OPI PSRAM.
# Forcing UNICORE=y can be merged after multicore defaults and break PSRAM / CPU1 startup.
# CONFIG_FREERTOS_UNICORE is not set

#
# TinyUSB Stack
#
CONFIG_TINYUSB=y
CONFIG_TINYUSB_DEBUG_LEVEL=0

#
# USB Network Class (RNDIS, ECM)
#
CONFIG_TINYUSB_NET_ENABLED=y
CONFIG_TINYUSB_RNDIS_VENDOR="Espressif Incorporated"
CONFIG_TINYUSB_NET_ECM=y

#
# ESP32S3-Specific
#
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ=240

#
# OPI Octal PSRAM @ 80MHz (memory-mapped; no SPIRAM heap on ESP-IDF v5.2.x workaround).
# ESP-IDF 5.2.x + Octal PSRAM: esp_psram_extram_add_to_heap_allocator can fault in
# heap_caps_add_region_with_caps (see IDFGH-14757 / upgrade to v5.3+ for unified heap fix).
# USE_MEMMAP skips that path; WiFi/lwIP cannot use CONFIG_SPIRAM_TRY_ALLOCATE_WIFI_LWIP (Kconfig requires malloc/caps).
# If your module has NO PSRAM, comment out all CONFIG_SPIRAM* below and fullclean rebuild.
#
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_BOOT_HW_INIT=y
CONFIG_SPIRAM_BOOT_INIT=y
CONFIG_SPIRAM_USE_MEMMAP=y
# CONFIG_SPIRAM_USE_CAPS_ALLOC is not set
# CONFIG_SPIRAM_USE_MALLOC is not set
# CONFIG_SPIRAM_TRY_ALLOCATE_WIFI_LWIP is not set
CONFIG_STDATOMIC_S32C1I_SPIRAM_WORKAROUND=y

CONFIG_USB_TASK_CORE_ID=1

#
# USB Host CDC options
#
CONFIG_CDC_SEND_DTE_ACTIVE=n
CONFIG_CDC_BULK_OUT_URB_BUFFER_SIZE=1536
CONFIG_CDC_BULK_IN_URB_BUFFER_SIZE=1536
CONFIG_CDC_BULK_IN_URB_NUM=4
CONFIG_CDC_BULK_OUT_URB_NUM=4

CONFIG_TINYUSB_NET_MODE_ECM_RNDIS=y

CONFIG_TINYUSB_TASK_AFFINITY_CPU0=y
CONFIG_TINYUSB_INIT_IN_DEFAULT_TASK=y
CONFIG_TINYUSB_NET_MODE_NCM=y
